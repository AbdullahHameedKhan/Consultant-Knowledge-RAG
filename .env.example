# Consultant Knowledge RAG — Configuration Template
# 
# Copy this file to .env and customize for your environment.
# Never commit the actual .env file to git (see .gitignore).
#
# For detailed documentation, see:
# - README.md (quick-start guide)
# - ARCHITECTURE.md (system design)
# - SECURITY.md (secrets management)

# ─────────────────────────────────────────────────────────────────
# OLLAMA CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Ollama server URL (local or remote)
# Local: http://localhost:11434
# Remote: https://ollama.company.com (requires OLLAMA_API_KEY below)
OLLAMA_BASE_URL=http://localhost:11434

# API key for remote Ollama (optional, leave blank for local)
# Generate with: openssl rand -hex 32
OLLAMA_API_KEY=

# LLM model to use for answer generation
# Options:
#   qwen2.5:3b     ← Recommended (fast, good quality, 3.8B params)
#   qwen2.5:1.5b   ← Smaller (faster but lower quality)
#   qwen2.5:7b     ← Larger (slower but higher quality)
#   llama2:7b      ← Alternative (good general purpose)
#   mistral:7b     ← Alternative (faster, reasonable quality)
# See README.md for model comparison
MODEL_NAME=qwen2.5:3b

# ─────────────────────────────────────────────────────────────────
# EMBEDDING MODEL CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Embedding server URL (separate from LLM)
# Typically same as OLLAMA_BASE_URL (shared service)
# But can be separate for large-scale deployments
EMBED_BASE_URL=http://localhost:11434

# API key for remote embedding service (optional)
EMBED_API_KEY=

# Embedding model to use
# Options:
#   nomic-embed-text   ← Recommended (768-dim, excellent quality)
#   mxbai-embed-large  ← Alternative (1024-dim, slightly better)
# Note: Dimension size must match VECTOR_SIZE below
EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────────────────────────
# DOCUMENT STORAGE & PATHS
# ─────────────────────────────────────────────────────────────────

# Directory where documents are stored (PDFs, DOCX, TXT)
# The app will scan this directory for new files on ingestion
# Create this directory before running the app
DOCUMENT_DIR=./internal_reports

# ─────────────────────────────────────────────────────────────────
# DOCUMENT CHUNKING STRATEGY
# ─────────────────────────────────────────────────────────────────

# Tokens per chunk (larger = more context per chunk, fewer total chunks)
# Typical range: 512–1024
# 768 balances:
#   - Context richness (need ~512+ tokens for complex concepts)
#   - Granularity (smaller = more precise retrieval)
#   - Memory (smaller chunks = lower vectors to store)
CHUNK_SIZE=768

# Overlap between consecutive chunks (helps with context continuity)
# Typical: 10–20% of CHUNK_SIZE
# 128 tokens = ~17% of 768 (good balance)
CHUNK_OVERLAP=128

# ─────────────────────────────────────────────────────────────────
# RETRIEVAL TUNING
# ─────────────────────────────────────────────────────────────────

# Number of chunks to retrieve from vector DB per query
# Typical: 4–8
# More chunks = broader context, longer latency
# Fewer chunks = faster, may miss relevant info
TOP_K=4

# Minimum cosine similarity score (0.0–1.0) to include in results
# Lower (e.g., 0.25) = more inclusive, may include noise
# Higher (e.g., 0.50) = strict filtering, may miss some relevant docs
# 0.35 balances recall and precision for consulting docs
SIMILARITY_THRESHOLD=0.35

# Number of chunks to pass to LLM for answer generation
# Typically ≤ TOP_K (we may filter further for length/quality)
# Lower = shorter context, faster generation
# Higher = richer context, better answers
GENERATION_TOP_K=4

# Maximum characters to show in source context (for UI display)
# Longer = more context visible to user
# Shorter = cleaner UI, may cut off important info
MAX_SOURCE_CHARS=500

# ─────────────────────────────────────────────────────────────────
# QDRANT VECTOR DATABASE
# ─────────────────────────────────────────────────────────────────

# Collection name (your knowledge base identifier)
# Can have multiple collections for multi-tenancy
# Format: consultant_kb, consultant_kb_acme, consultant_kb_techcorp, etc.
QDRANT_COLLECTION=consultant_kb

# Vector embedding dimension (must match embedding model output)
# nomic-embed-text → 768
# mxbai-embed-large → 1024
VECTOR_SIZE=768

# Local path for Qdrant storage (optional)
# If set, uses local mode (good for small deployments, testing)
# Leave blank to use URL-based connection
QDRANT_PATH=

# Qdrant server URL (remote)
# Local: http://localhost:6333
# Remote: https://qdrant.company.com
# Only used if QDRANT_PATH is blank
QDRANT_URL=http://localhost:6333

# ─────────────────────────────────────────────────────────────────
# LANGUAGE MODEL PARAMETERS
# ─────────────────────────────────────────────────────────────────

# Context window size (tokens the model can see)
# Typical for qwen2.5:3b: 4096 (default in Ollama)
# Larger = can handle longer prompts, uses more memory
# Our setting (2048) is conservative for safety
LLM_NUM_CTX=2048

# Maximum tokens to generate per response
# Typical: 500–1000
# 600 is good for consultant answers (3–5 paragraphs)
# Lower = faster generation, shorter answers
# Higher = more detailed answers, slower
MAX_OUTPUT_TOKENS=600

# ─────────────────────────────────────────────────────────────────
# FASTAPI SERVER
# ─────────────────────────────────────────────────────────────────

# Host to bind to
# 127.0.0.1 = localhost only (default, safe)
# 0.0.0.0 = accept connections from anywhere (for Docker)
API_HOST=127.0.0.1

# Port to run on
# 8000 = typical development port
# 5000 = alternative
# Requires root for ports < 1024
API_PORT=8000

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: MULTI-TENANCY & SECURITY
# ─────────────────────────────────────────────────────────────────

# Tenant API keys (JSON format, optional)
# Example: {"acme-corp": "secret-key-1", "techcorp": "secret-key-2"}
# If using multi-tenancy, uncomment and set:
# TENANT_API_KEYS={"acme-corp": "acme-secret-12345", "techcorp": "tech-secret-67890"}

# JWT secret (optional, for future auth)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# JWT_SECRET=your-secret-key-here

# ─────────────────────────────────────────────────────────────────
# LOGGING & DEBUG
# ─────────────────────────────────────────────────────────────────

# Log level
# DEBUG = very verbose (for development)
# INFO = normal (default, for production)
# WARNING = only warnings and errors
# ERROR = only errors
# LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────────

# 1. Before running:
#    - Copy this file to .env
#    - Make sure Ollama is running: ollama serve
#    - Make sure Qdrant is running: docker run -p 6333:6333 qdrant/qdrant
#
# 2. Models to download:
#    - ollama pull qwen2.5:3b
#    - ollama pull nomic-embed-text
#
# 3. Verify setup:
#    - curl http://localhost:11434/api/tags (Ollama)
#    - curl http://localhost:6333/health (Qdrant)
#
# 4. For production, use Secrets Manager (AWS, Azure, HashiCorp Vault)
#    instead of .env file. See SECURITY.md for details.
#
# 5. Never commit .env to git. The .gitignore file already protects it.
#
# 6. For Docker deployment, pass vars via --env-file or -e flags:
#    docker-compose --env-file .env up
#
# ─────────────────────────────────────────────────────────────────
